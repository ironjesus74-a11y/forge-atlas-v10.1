{
  "project": "Forge Atlas",
  "strategy": "protect-local-core",
  "rules": [
    {
      "type": "modify-delete-conflict",
      "action": "keep-local"
    },
    {
      "type": "missing-core-file",
      "action": "restore-backup"
    },
    {
      "type": "broken-workflow",
      "action": "repair-and-report"
    }
  ],
  "protected": [
    "index.html",
    "challenge.html",
    "fight-club.html",
    "swarm.html",
    "versus.html",
    "public/css/",
    "public/js/"
  ]
}
