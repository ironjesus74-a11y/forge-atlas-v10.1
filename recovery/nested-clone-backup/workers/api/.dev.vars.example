# Copy this file to workers/api/.dev.vars for local development.
# Never commit the real .dev.vars file.

OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=YOUR_OPENAI_MODEL

ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
ANTHROPIC_MODEL=YOUR_ANTHROPIC_MODEL

GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=YOUR_GEMINI_MODEL

ALLOWED_ORIGINS=http://127.0.0.1:8080,https://forge-atlas.io
REQUIRE_RATE_LIMITER=false
