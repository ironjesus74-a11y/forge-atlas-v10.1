  // ---- ATLAS ID ----
  function initAtlasID(){
    var form = $('#atlas-id-form');
    if(!form) return;
    var saved = ls_get('fa.atlasId', null);
    var fields = ['callsign','rank','archetype','specialty','bio','model','team','swarm'];

    function readForm(){
      var out = {};
      fields.forEach(function(k){
        var el = form.querySelector('[name="'+k+'"]');
        if(el) out[k] = el.value || '';
      });
      out.badges = $$('input[name="badges"]:checked', form).map(function(b){ return b.value; });
      return out;
    }
    function writeCard(d){
      safeText($('#card-callsign'), d.callsign || 'UNCLAIMED');
      safeText($('#card-rank'), (d.rank || 'Initiate') + ' · ' + (d.archetype || 'Builder'));
      safeText($('#card-bio'), d.bio || 'No bio set. Tell the network who you are.');
      safeText($('#card-spec'), d.specialty || 'Generalist Operator');
      safeText($('#card-model'), d.model || '—');
      safeText($('#card-team'), d.team || '—');
      safeText($('#card-swarm'), d.swarm || '—');
      var bw = $('#card-badges');
      if(bw){
        bw.textContent = '';
        if(d.badges && d.badges.length){
          d.badges.forEach(function(b){
            var t = document.createElement('span'); t.className = 'tag gold'; t.textContent = b;
            bw.appendChild(t);
          });
        } else {
          var t = document.createElement('span'); t.className = 'tag'; t.textContent = 'No badges yet';
          bw.appendChild(t);
        }
      }
    }
    function fillForm(d){
      if(!d) return;
      fields.forEach(function(k){
        var el = form.querySelector('[name="'+k+'"]');
        if(el && d[k] != null) el.value = d[k];
      });
      $$('input[name="badges"]', form).forEach(function(b){
        b.checked = (d.badges||[]).indexOf(b.value) >= 0;
      });
    }
    if(saved){ fillForm(saved); writeCard(saved); }
    else { writeCard(readForm()); }
    on(form, 'input', function(){ writeCard(readForm()); });
    on(form, 'change', function(){ writeCard(readForm()); });
    on(form, 'submit', function(e){
      e.preventDefault();
      var d = readForm();
      ls_set('fa.atlasId', d);
      writeCard(d);
      var ack = $('#id-ack');
      if(ack){ ack.hidden = false; safeText(ack, '✓ Atlas ID saved locally. Backend sync requires a future server.'); }
    });
    on($('#id-reset'), 'click', function(){
      try{ localStorage.removeItem('fa.atlasId'); }catch(_){}
      form.reset();
      writeCard(readForm());
      var ack = $('#id-ack');
      if(ack) ack.hidden = true;
    });
  }

