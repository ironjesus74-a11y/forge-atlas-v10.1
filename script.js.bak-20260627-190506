  function safeText(el, txt){ if(el) el.textContent = String(txt==null?'':txt); }
  function ls_get(k, fallback){ try{ var v = localStorage.getItem(k); return v==null ? fallback : JSON.parse(v); } catch(e){ return fallback; } }
  function ls_set(k, v){ try{ localStorage.setItem(k, JSON.stringify(v)); return true; } catch(e){ return false; } }

